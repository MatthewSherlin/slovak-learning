# ── LLM provider ─────────────────────────────────────────────────────
# Provider: "anthropic" (default) or "openrouter"
# SLOVAK_LLM_PROVIDER=anthropic

# Anthropic
SLOVAK_ANTHROPIC_API_KEY=your-anthropic-api-key-here
# SLOVAK_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenRouter (used when SLOVAK_LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=sk-or-v1-...
# SLOVAK_OPENROUTER_MODEL=google/gemini-2.5-flash
